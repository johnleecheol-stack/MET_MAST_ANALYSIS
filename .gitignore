# Output files (generated, not tracked)
output/*
!output/.gitkeep

# Input data (sensitive/large)
input/sample/*.txt
input/sample/*.pdf
!input/sample/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Charts (generated)
*.png
!docs/

# Fonts (binary, large — committed once)
# fonts/ files are kept in git
